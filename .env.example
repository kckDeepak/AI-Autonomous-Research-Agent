# Core app
APP_ENV=development
APP_NAME=Autonomous Research Agent
LOG_LEVEL=INFO

# Runtime controls
MAX_SOURCES_DEFAULT=20
MAX_QUERIES_PER_PLAN=6
GLOBAL_RUN_TIMEOUT_MINUTES=20
PER_URL_TIMEOUT_SECONDS=20
LLM_TOKEN_BUDGET_PER_RUN=25000
FETCH_MAX_CONCURRENCY=8
EXTRACTION_MIN_CHARS=700
SUMMARY_CHUNK_CHARS=3000
SUMMARY_CHUNK_OVERLAP=300
MAX_SUMMARY_CHUNKS_PER_SOURCE=4
MIN_RELEVANCE_SCORE=0.45
NOTION_VERSION=2022-06-28
NOTION_REQUEST_TIMEOUT_SECONDS=20
GMAIL_REQUEST_TIMEOUT_SECONDS=20
SLACK_REQUEST_TIMEOUT_SECONDS=10
HARD_MAX_SOURCES=50
HARD_MAX_QUERIES_PER_PLAN=12
HARD_LLM_TOKEN_BUDGET_PER_RUN=120000
REQUEST_MAX_CHARS=1000
ALERT_FAILURE_THRESHOLD=3
ALERT_WINDOW_MINUTES=60

# LLM provider selection
LLM_PROVIDER=openai
OPENAI_MODEL_PLANNER=gpt-5-mini
OPENAI_MODEL_SUMMARIZER=gpt-5-mini
OPENAI_MODEL_REPORTER=gpt-5
ANTHROPIC_MODEL_PLANNER=claude-3-7-sonnet-latest
ANTHROPIC_MODEL_SUMMARIZER=claude-3-7-sonnet-latest
ANTHROPIC_MODEL_REPORTER=claude-3-7-sonnet-latest

# Required secrets
OPENAI_API_KEY=
TAVILY_API_KEY=
NOTION_TOKEN=
NOTION_DATABASE_ID=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# Optional
SLACK_WEBHOOK_URL=
SENTRY_DSN=
